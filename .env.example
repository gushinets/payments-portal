# Shared local defaults for the Docker API container
DATABASE_URL=postgresql+psycopg://anytoolai:anytoolai@postgres:5432/anytoolai

# PostgreSQL container
POSTGRES_DB=anytoolai
POSTGRES_USER=anytoolai
POSTGRES_PASSWORD=anytoolai
POSTGRES_PORT=5432

# Local HTTP entrypoints
API_PORT=8000
CADDY_PORT=8080
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:3000

# Frontend public values are captured when Next.js starts/builds
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_TELEGRAM_LOGIN_URL=
NEXT_ALLOWED_DEV_ORIGINS=192.168.1.102

# CloudPayments demo mode by default
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
CLOUDPAYMENTS_ENABLED=false
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=
NEXT_PUBLIC_CLOUDPAYMENTS_ENABLED=false
