{
  "name": "anytoolai-payments-portal",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "repo:doctor": "python scripts/repo.py doctor",
    "repo:setup": "python scripts/repo.py setup",
    "repo:up": "python scripts/repo.py up",
    "repo:down": "python scripts/repo.py down",
    "repo:reset": "python scripts/repo.py reset",
    "docs:check": "python scripts/repo.py docs check",
    "generate": "python scripts/repo.py generate",
    "generate:check": "python scripts/repo.py generate --check",
    "architecture:check": "python scripts/repo.py architecture check",
    "check:fast": "python scripts/repo.py check --fast",
    "check": "python scripts/repo.py check",
    "test:e2e": "npm exec playwright test -- --config playwright.config.ts",
    "playwright:install": "npm exec playwright install chromium",
    "dev:web": "npm --workspace @anytoolai/web run dev",
    "start:web": "npm --workspace @anytoolai/web run start",
    "build:web": "npm --workspace @anytoolai/web run build",
    "lint:web": "npm --workspace @anytoolai/web run lint",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api",
    "test:api": "pytest apps/api/tests"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
