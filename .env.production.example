# PostgreSQL
POSTGRES_DB=anytoolai
POSTGRES_USER=anytoolai
POSTGRES_PASSWORD=replace-with-a-secret
DATABASE_URL=postgresql+psycopg://anytoolai:replace-with-a-secret@postgres:5432/anytoolai

# Published ports and browser API URL
WEB_PORT=80
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
CORS_ALLOW_ORIGINS=https://example.com

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
CLOUDPAYMENTS_ENABLED=false
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=
NEXT_PUBLIC_CLOUDPAYMENTS_ENABLED=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=anytoolai-payment-portal-api
