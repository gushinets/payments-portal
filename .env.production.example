# PostgreSQL
POSTGRES_DB=anytoolai
POSTGRES_USER=anytoolai
POSTGRES_PASSWORD=replace-with-a-secret
DATABASE_URL=postgresql+psycopg://anytoolai:replace-with-a-secret@postgres:5432/anytoolai

# Caddy public entrypoint
CADDY_DOMAIN=payments.example.com
CORS_ALLOW_ORIGINS=https://example.com

# Frontend public values are captured during the Docker web image build
NEXT_PUBLIC_API_BASE_URL=https://payments.example.com
NEXT_PUBLIC_TELEGRAM_LOGIN_URL=

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=replace-with-cloudpayments-public-id
CLOUDPAYMENTS_API_SECRET=replace-with-cloudpayments-api-secret
CLOUDPAYMENTS_ENABLED=false
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=replace-with-cloudpayments-public-id
NEXT_PUBLIC_CLOUDPAYMENTS_ENABLED=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=anytoolai-payment-portal-api
