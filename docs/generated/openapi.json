{
  "components": {
    "schemas": {
      "AcceptDocumentRequest": {
        "properties": {
          "acceptance_text_hash": {
            "maxLength": 256,
            "minLength": 32,
            "title": "Acceptance Text Hash",
            "type": "string"
          },
          "document_version_id": {
            "format": "uuid",
            "title": "Document Version Id",
            "type": "string"
          },
          "entrypoint_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Entrypoint Type"
          },
          "entrypoint_value": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Entrypoint Value"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          }
        },
        "required": [
          "document_version_id",
          "acceptance_text_hash"
        ],
        "title": "AcceptDocumentRequest",
        "type": "object"
      },
      "CheckoutIntentRequest": {
        "properties": {
          "auto_renew": {
            "default": false,
            "title": "Auto Renew",
            "type": "boolean"
          },
          "entrypoint_type": {
            "default": "product",
            "title": "Entrypoint Type",
            "type": "string"
          },
          "frontend_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frontend Id"
          },
          "plan_code": {
            "title": "Plan Code",
            "type": "string"
          },
          "product": {
            "title": "Product",
            "type": "string"
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          }
        },
        "required": [
          "product",
          "plan_code"
        ],
        "title": "CheckoutIntentRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "region": {
            "default": "ru",
            "title": "Region",
            "type": "string"
          },
          "tenant_id": {
            "default": "anytoolai",
            "title": "Tenant Id",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "offer_consent": {
            "title": "Offer Consent",
            "type": "boolean"
          },
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "personal_consent": {
            "title": "Personal Consent",
            "type": "boolean"
          },
          "region": {
            "default": "ru",
            "title": "Region",
            "type": "string"
          },
          "tenant_id": {
            "default": "anytoolai",
            "title": "Tenant Id",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password",
          "personal_consent",
          "offer_consent"
        ],
        "title": "RegisterRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
